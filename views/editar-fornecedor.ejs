<%- include('partials/header', { titulo: 'Editar Fornecedor' }) %>

<main class="fornecedor-erp-page">
  <div class="fornecedor-erp-card">
    <div class="fornecedor-erp-header">
      <h1>Editar Fornecedor</h1>
    </div>

    <% if (erro) { %>
      <div class="alert alert-error fornecedor-erp-alert">
        <%= erro %>
      </div>
    <% } %>

    <form action="/fornecedores/editar/<%= dados.id %>" method="POST">
      <div class="fornecedor-erp-columns">
        <div class="fornecedor-erp-col">
          <section class="forn-box">
            <div class="forn-box-title">Dados de identificação</div>

            <div class="forn-grid">
              <div class="forn-field">
                <label for="cnpj">CNPJ <span>*</span></label>
                <input
                  type="text"
                  id="cnpj"
                  name="cnpj"
                  value="<%= dados.cnpj || '' %>"
                  placeholder="00.000.000/0000-00"
                  maxlength="18"
                  inputmode="numeric"
                  oninput="mascaraCNPJ(this)"
                  required
                >
              </div>

              <div class="forn-field">
                <label for="inscricaoEstadual">Insc. estadual</label>
                <input
                  type="text"
                  id="inscricaoEstadual"
                  name="inscricaoEstadual"
                  value="<%= dados.inscricaoEstadual || '' %>"
                  placeholder="Somente números"
                  inputmode="numeric"
                  oninput="somenteNumeros(this)"
                >
              </div>

              <div class="forn-field">
                <label for="razaoSocial">Razão social <span>*</span></label>
                <input
                  type="text"
                  id="razaoSocial"
                  name="razaoSocial"
                  value="<%= dados.razaoSocial || '' %>"
                  placeholder="Insira a razão social"
                  required
                >
              </div>

              <div class="forn-field">
                <label for="nomeFantasia">Nome fantasia</label>
                <input
                  type="text"
                  id="nomeFantasia"
                  name="nomeFantasia"
                  value="<%= dados.nomeFantasia || '' %>"
                  placeholder="Insira o nome fantasia"
                >
              </div>

              <div class="forn-field">
                <label for="responsavel">Responsável</label>
                <input
                  type="text"
                  id="responsavel"
                  name="responsavel"
                  value="<%= dados.responsavel || '' %>"
                  placeholder="Insira um nome"
                >
              </div>

              <div class="forn-field">
                <label for="cpf">CPF</label>
                <input
                  type="text"
                  id="cpf"
                  name="cpf"
                  value="<%= dados.cpf || '' %>"
                  placeholder="000.000.000-00"
                  maxlength="14"
                  inputmode="numeric"
                  oninput="mascaraCPF(this)"
                >
              </div>
            </div>
          </section>

          <section class="forn-box">
            <div class="forn-box-title">Dados de contato</div>

            <div class="forn-grid">
              <div class="forn-field">
                <label for="telefone">Telefone <span>*</span></label>
                <input
                  type="text"
                  id="telefone"
                  name="telefone"
                  value="<%= dados.telefone || '' %>"
                  placeholder="(00) 0000-0000"
                  maxlength="15"
                  inputmode="numeric"
                  oninput="mascaraTelefone(this)"
                  required
                >
              </div>

              <div class="forn-field">
                <label for="celular">Celular</label>
                <input
                  type="text"
                  id="celular"
                  name="celular"
                  value="<%= dados.celular || '' %>"
                  placeholder="(00) 00000-0000"
                  maxlength="15"
                  inputmode="numeric"
                  oninput="mascaraTelefone(this)"
                >
              </div>

              <div class="forn-field forn-span-2">
                <label for="email">E-mail <span>*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  value="<%= dados.email || '' %>"
                  placeholder="Insira um e-mail"
                  required
                >
              </div>
            </div>
          </section>
        </div>

        <div class="fornecedor-erp-col">
          <section class="forn-box">
            <div class="forn-box-title">Dados de endereço</div>

            <div class="forn-grid">
              <div class="forn-field">
                <label for="cep">CEP</label>
                <input
                  type="text"
                  id="cep"
                  name="cep"
                  value="<%= dados.cep || '' %>"
                  placeholder="00000-000"
                  maxlength="9"
                  inputmode="numeric"
                  oninput="mascaraCEP(this)"
                  onblur="buscarCep(this)"
                >
              </div>

              <div class="forn-field">
                <label for="estado">Estado</label>
                <select id="estado" name="estado">
                  <option value="">Selecione</option>
                  <option value="AC" <%= dados.estado === 'AC' ? 'selected' : '' %>>AC</option>
                  <option value="AL" <%= dados.estado === 'AL' ? 'selected' : '' %>>AL</option>
                  <option value="AP" <%= dados.estado === 'AP' ? 'selected' : '' %>>AP</option>
                  <option value="AM" <%= dados.estado === 'AM' ? 'selected' : '' %>>AM</option>
                  <option value="BA" <%= dados.estado === 'BA' ? 'selected' : '' %>>BA</option>
                  <option value="CE" <%= dados.estado === 'CE' ? 'selected' : '' %>>CE</option>
                  <option value="DF" <%= dados.estado === 'DF' ? 'selected' : '' %>>DF</option>
                  <option value="ES" <%= dados.estado === 'ES' ? 'selected' : '' %>>ES</option>
                  <option value="GO" <%= dados.estado === 'GO' ? 'selected' : '' %>>GO</option>
                  <option value="MA" <%= dados.estado === 'MA' ? 'selected' : '' %>>MA</option>
                  <option value="MT" <%= dados.estado === 'MT' ? 'selected' : '' %>>MT</option>
                  <option value="MS" <%= dados.estado === 'MS' ? 'selected' : '' %>>MS</option>
                  <option value="MG" <%= dados.estado === 'MG' ? 'selected' : '' %>>MG</option>
                  <option value="PA" <%= dados.estado === 'PA' ? 'selected' : '' %>>PA</option>
                  <option value="PB" <%= dados.estado === 'PB' ? 'selected' : '' %>>PB</option>
                  <option value="PR" <%= dados.estado === 'PR' ? 'selected' : '' %>>PR</option>
                  <option value="PE" <%= dados.estado === 'PE' ? 'selected' : '' %>>PE</option>
                  <option value="PI" <%= dados.estado === 'PI' ? 'selected' : '' %>>PI</option>
                  <option value="RJ" <%= dados.estado === 'RJ' ? 'selected' : '' %>>RJ</option>
                  <option value="RN" <%= dados.estado === 'RN' ? 'selected' : '' %>>RN</option>
                  <option value="RS" <%= dados.estado === 'RS' ? 'selected' : '' %>>RS</option>
                  <option value="RO" <%= dados.estado === 'RO' ? 'selected' : '' %>>RO</option>
                  <option value="RR" <%= dados.estado === 'RR' ? 'selected' : '' %>>RR</option>
                  <option value="SC" <%= dados.estado === 'SC' ? 'selected' : '' %>>SC</option>
                  <option value="SP" <%= dados.estado === 'SP' ? 'selected' : '' %>>SP</option>
                  <option value="SE" <%= dados.estado === 'SE' ? 'selected' : '' %>>SE</option>
                  <option value="TO" <%= dados.estado === 'TO' ? 'selected' : '' %>>TO</option>
                </select>
              </div>

              <div class="forn-field">
                <label for="cidade">Cidade</label>
                <input
                  type="text"
                  id="cidade"
                  name="cidade"
                  value="<%= dados.cidade || '' %>"
                  placeholder="Cidade"
                >
              </div>

              <div class="forn-field">
                <label for="bairro">Bairro</label>
                <input
                  type="text"
                  id="bairro"
                  name="bairro"
                  value="<%= dados.bairro || '' %>"
                  placeholder="Bairro"
                >
              </div>

              <div class="forn-field forn-span-2">
                <label for="endereco">Endereço</label>
                <input
                  type="text"
                  id="endereco"
                  name="endereco"
                  value="<%= dados.endereco || '' %>"
                  placeholder="Endereço"
                >
              </div>

              <div class="forn-field">
                <label for="numero">Número</label>
                <input
                  type="text"
                  id="numero"
                  name="numero"
                  value="<%= dados.numero || '' %>"
                  placeholder="Número"
                >
              </div>

              <div class="forn-field">
                <label for="complemento">Complemento</label>
                <input
                  type="text"
                  id="complemento"
                  name="complemento"
                  value="<%= dados.complemento || '' %>"
                  placeholder="Complemento"
                >
              </div>
            </div>
          </section>

          <section class="forn-box">
            <div class="forn-box-title">Outros</div>

            <div class="forn-grid">
              <div class="forn-field forn-span-2">
                <label for="observacoes">Observações</label>
                <textarea
                  id="observacoes"
                  name="observacoes"
                  rows="5"
                  placeholder="Insira uma observação..."
                ><%= dados.observacoes || '' %></textarea>
              </div>
            </div>
          </section>
        </div>
      </div>

      <div class="fornecedor-erp-footer">
        <a href="/fornecedores" class="forn-footer-btn forn-footer-cancel">← Cancelar</a>
        <button type="submit" class="forn-footer-btn forn-footer-save">✔ Salvar</button>
      </div>
    </form>
  </div>
</main>

<script src="/javascripts/mascaras.js"></script>
<script src="/javascripts/fornecedor-validacao.js"></script>