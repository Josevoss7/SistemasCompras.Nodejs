<%- include('partials/header', { titulo: 'Editar Ordem de Compra' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Editar Ordem de Compra</h1>
    <a href="/ordens-compra" class="btn-secondary">Voltar</a>
  </div>

  <div class="form-wrapper">
    <% if (erro) { %>
      <div class="alert alert-error">
        <%= erro %>
      </div>
    <% } %>

    <form action="/ordens-compra/editar/<%= dados.id %>" method="POST" class="form-grid">
      <div class="form-group form-group-full">
        <label for="requisicao_id">Requisição Atendida</label>
        <select id="requisicao_id" name="requisicao_id">
          <option value="">Selecione uma requisição</option>
          <% requisicoes.forEach(requisicao => { %>
            <option
              value="<%= requisicao.id %>"
              <%= String(dados.requisicao_id || '') === String(requisicao.id) ? 'selected' : '' %>>
              #<%= requisicao.id %> - <%= requisicao.solicitante %> - <%= requisicao.setor %> - <%= requisicao.produto_nome || 'Sem produto' %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="fornecedor_id">Fornecedor</label>
        <select id="fornecedor_id" name="fornecedor_id">
          <option value="">Selecione um fornecedor</option>
          <% fornecedores.forEach(fornecedor => { %>
            <option
              value="<%= fornecedor.id %>"
              <%= String(dados.fornecedor_id || '') === String(fornecedor.id) ? 'selected' : '' %>>
              <%= fornecedor.nome %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="produto_id">Produto</label>
        <select id="produto_id" name="produto_id">
          <option value="">Selecione um produto</option>
          <% produtos.forEach(produto => { %>
            <option
              value="<%= produto.id %>"
              <%= String(dados.produto_id || '') === String(produto.id) ? 'selected' : '' %>>
              <%= produto.nome %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="quantidade">Quantidade</label>
        <input
          type="number"
          id="quantidade"
          name="quantidade"
          min="1"
          value="<%= dados.quantidade || 1 %>">
      </div>

      <div class="form-group">
        <label for="preco_unitario">Preço Unitário</label>
        <input
          type="number"
          step="0.01"
          id="preco_unitario"
          name="preco_unitario"
          value="<%= dados.preco_unitario || '' %>">
      </div>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <option value="ABERTA" <%= (dados.status || 'ABERTA') === 'ABERTA' ? 'selected' : '' %>>ABERTA</option>
          <option value="APROVADA" <%= dados.status === 'APROVADA' ? 'selected' : '' %>>APROVADA</option>
          <option value="ATENDIDA" <%= dados.status === 'ATENDIDA' ? 'selected' : '' %>>ATENDIDA</option>
        </select>
      </div>

      <div class="form-group form-group-full">
        <label for="observacoes">Observações</label>
        <textarea id="observacoes" name="observacoes" rows="4"><%= dados.observacoes || '' %></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Salvar Alterações</button>
      </div>
    </form>
  </div>
</main>

<%- include('partials/footer') %>