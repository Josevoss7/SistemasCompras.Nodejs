<%- include('partials/header', { titulo: 'Ordens de Compra' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Ordens de Compra</h1>
    <a href="/ordens-compra/nova" class="btn-primary">Nova Ordem de Compra</a>
  </div>

  <% if (mensagem) { %>
    <div class="alert alert-success">
      <%= mensagem %>
    </div>
  <% } %>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Requisição</th>
          <th>Fornecedor</th>
          <th>Produto</th>
          <th>Quantidade</th>
          <th>Preço Unitário</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% ordens.forEach(function(ordem) { %>
          <tr>
            <td><%= ordem.id %></td>

            <td>
              <% if (ordem.requisicao_id) { %>
                #<%= ordem.requisicao_id %> - <%= ordem.requisicao_solicitante || '-' %>
              <% } else { %>
                -
              <% } %>
            </td>

            <td><%= ordem.fornecedor_nome || '-' %></td>
            <td><%= ordem.produto_nome || '-' %></td>
            <td><%= ordem.quantidade || '-' %></td>
            <td>R$ <%= Number(ordem.preco_unitario || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            <td>
              <span class="status-badge
                <%= ordem.status === 'ABERTA' ? 'status-aberta' : '' %>
                <%= ordem.status === 'APROVADA' ? 'status-aprovada' : '' %>
                <%= ordem.status === 'ATENDIDA' ? 'status-atendida' : '' %>">
                <%= ordem.status %>
              </span>
            </td>
            <td>
              <div class="acoes-tabela">
                <a href="/ordens-compra/editar/<%= ordem.id %>" class="btn-editar">Editar</a>
                <form action="/ordens-compra/excluir/<%= ordem.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta ordem de compra?');">
                  <button type="submit" class="btn-excluir">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('partials/footer') %>