<%- include('partials/header', { titulo: 'Requisições' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Requisições</h1>
    <a href="/requisicoes/nova" class="btn-primary">Nova Requisição</a>
  </div>

  <% if (mensagem) { %>
    <div class="alert alert-success">
      <%= mensagem %>
    </div>
  <% } %>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Solicitante</th>
          <th>Setor</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% requisicoes.forEach(function(requisicao) { %>
          <tr>
            <td><%= requisicao.id %></td>
            <td><%= requisicao.solicitante %></td>
            <td><%= requisicao.setor %></td>
            <td><span class="status-badge status-pendente"><%= requisicao.status %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('partials/footer') %>