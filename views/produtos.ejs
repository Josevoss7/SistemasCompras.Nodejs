<%- include('partials/header', { titulo: 'Produtos' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Produtos</h1>
    <a href="/produtos/novo" class="btn-primary">Novo Produto</a>
  </div>

  <% if (mensagem) { %>
    <div class="alert alert-success">
      <%= mensagem %>
    </div>
  <% } %>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Categoria</th>
          <th>Preço</th>
          <th>Estoque</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% produtos.forEach(function(produto) { %>
          <tr>
            <td><%= produto.id %></td>
            <td><%= produto.nome %></td>
            <td><%= produto.categoria %></td>
            <td>R$ <%= Number(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            <td><%= produto.estoque %></td>
            <td>
                <div class="acoes-tabela">
                <a href="/produtos/editar/<%= produto.id %>" class="btn-editar">
                Editar
                </a>

               <form action="/produtos/excluir/<%= produto.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este produto?');">
               <button type="submit" class="btn-excluir">
               Excluir
            </button>
          </form>
        </div>
      </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('partials/footer') %>