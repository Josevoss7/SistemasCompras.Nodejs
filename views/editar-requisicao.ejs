<%- include('partials/header', { titulo: 'Editar Requisição' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Editar Requisição</h1>
    <a href="/requisicoes" class="btn-secondary">Voltar</a>
  </div>

  <div class="form-wrapper">
    <% if (erro) { %>
      <div class="alert alert-error">
        <%= erro %>
      </div>
    <% } %>

    <form action="/requisicoes/editar/<%= dados.id %>" method="POST" class="form-grid">
      <div class="form-group">
        <label for="solicitante">Solicitante</label>
        <input
          type="text"
          id="solicitante"
          name="solicitante"
          value="<%= dados.solicitante || '' %>"
          placeholder="Digite o nome do solicitante"
        >
      </div>

      <div class="form-group">
        <label for="setor">Setor</label>
        <input
          type="text"
          id="setor"
          name="setor"
          value="<%= dados.setor || '' %>"
          placeholder="Ex: Compras, TI, Financeiro"
        >
      </div>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <option value="ABERTA" <%= (dados.status || 'ABERTA') === 'ABERTA' ? 'selected' : '' %>>ABERTA</option>
          <option value="APROVADA" <%= dados.status === 'APROVADA' ? 'selected' : '' %>>APROVADA</option>
          <option value="ATENDIDA" <%= dados.status === 'ATENDIDA' ? 'selected' : '' %>>ATENDIDA</option>
        </select>
      </div>

      <div class="form-group">
        <label for="produto_id">Produto</label>
        <select id="produto_id" name="produto_id">
          <option value="">Selecione um produto</option>
          <% produtos.forEach(produto => { %>
            <option
              value="<%= produto.id %>"
              <%= String(dados.produto_id || '') === String(produto.id) ? 'selected' : '' %>>
              <%= produto.nome %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="quantidade">Quantidade</label>
        <input
          type="number"
          id="quantidade"
          name="quantidade"
          min="1"
          value="<%= dados.quantidade || 1 %>"
          placeholder="1"
        >
      </div>

      <div class="form-group form-group-full">
        <label for="observacoes">Observações</label>
        <textarea
          id="observacoes"
          name="observacoes"
          rows="4"
          placeholder="Digite observações da requisição"
        ><%= dados.observacoes || '' %></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Salvar Alterações</button>
      </div>
    </form>
  </div>
</main>

<%- include('partials/footer') %>