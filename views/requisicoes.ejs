<%- include('partials/header', { titulo: 'Requisições' }) %>
<%- include('partials/navbar') %>

<main class="container">
  <div class="page-header">
    <h1>Requisições</h1>
    <a href="/requisicoes/nova" class="btn-primary">Nova Requisição</a>
  </div>

  <% if (mensagem) { %>
    <div class="alert alert-success">
      <%= mensagem %>
    </div>
  <% } %>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Solicitante</th>
          <th>Setor</th>
          <th>Produto</th>
          <th>Quantidade</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% requisicoes.forEach(function(requisicao) { %>
          <tr>
            <td><%= requisicao.id %></td>
            <td><%= requisicao.solicitante %></td>
            <td><%= requisicao.setor %></td>
            <td><%= requisicao.produto_nome || '-' %></td>
            <td><%= requisicao.quantidade || '-' %></td>
            <td>
              <span class="status-badge
                <%= requisicao.status === 'ABERTA' ? 'status-aberta' : '' %>
                <%= requisicao.status === 'APROVADA' ? 'status-aprovada' : '' %>
                <%= requisicao.status === 'ATENDIDA' ? 'status-atendida' : '' %>">
                <%= requisicao.status %>
              </span>
            </td>
            <td>
              <div class="acoes-tabela">
                <a href="/requisicoes/editar/<%= requisicao.id %>" class="btn-editar">Editar</a>

                <form action="/requisicoes/excluir/<%= requisicao.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta requisição?');">
                  <button type="submit" class="btn-excluir">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('partials/footer') %>